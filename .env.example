# ============================================================
# .env.example — BagaskaraBot
# Salin file ini ke .env dan isi dengan nilai yang sesuai
# JANGAN commit .env ke git!
# ============================================================

# ── Google Sheets ─────────────────────────────────────────
GOOGLE_SHEETS_ID=your_spreadsheet_id_here
GOOGLE_CREDENTIALS_PATH=./credentials.json

# ── Binderbyte API (Tracking Resi) ────────────────────────
# Bisa isi beberapa key dipisah koma untuk fallback otomatis
BINDERBYTE_API_KEYS=key1,key2,key3

# ── Dashboard ─────────────────────────────────────────────
DASHBOARD_PORT=3001
# Token autentikasi dashboard (kosongkan untuk dev mode tanpa auth)
# Akses: http://localhost:3001?token=your_token_here
DASHBOARD_TOKEN=

# ── WhatsApp ──────────────────────────────────────────────
# Nomor admin yang bisa pakai fitur bulk check (format: 628xxx@c.us)
ADMIN_NUMBERS=628xxxxxxxxxx@c.us

# ── Laporan Harian WhatsApp ───────────────────────────────
# JID grup untuk laporan stok otomatis setiap pagi 08:00 WIB
# Format: 628xxxxx-timestamp@g.us (dapatkan dari !status di grup)
REPORT_GROUP_JID=

# ── Shopee ────────────────────────────────────────────────
# (Opsional) Cookie session Shopee untuk monitoring stok
SHOPEE_SESSION_COOKIE=
